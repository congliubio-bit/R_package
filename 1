library(dplyr)
library(rlang)
library(pharmaverseadam)

# 1. Load the data
data("adtte_onco")

# 2. Updated Function based on exact colnames
generate_censoring_summary <- function(dataset, endpoint_param, pop_col = NULL, pop_val = "Y") {
  
  # Step A: Filter for the Endpoint
  df_filtered <- dataset %>%
    filter(PARAMCD == endpoint_param)
  
  # Step B: Optional Population Filter (if the column exists)
  if (!is.null(pop_col)) {
    if (pop_col %in% colnames(df_filtered)) {
      df_filtered <- df_filtered %>%
        filter(.data[[pop_col]] == pop_val)
    } else {
      warning(sprintf("Column '%s' not found. Running on all subjects for this endpoint.", pop_col))
    }
  }
  
  # Step C: Calculate metrics
  n_total <- nrow(df_filtered)
  
  if (n_total == 0) {
    stop("No data found for this endpoint/population.")
  }
  
  n_events <- sum(df_filtered$CNSR == 0, na.rm = TRUE)
  n_censored <- sum(df_filtered$CNSR > 0, na.rm = TRUE)
  
  # Step D: Censor Reasons (using EVNTDESC)
  censor_reasons <- df_filtered %>%
    filter(CNSR > 0) %>%
    group_by(EVNTDESC) %>%
    summarise(Count = n(), .groups = 'drop') %>%
    mutate(Percent = (Count / n_total) * 100) %>%
    arrange(desc(Count))
  
  # Step E: Print to Console EXACTLY matching your feature notes
  cat(sprintf("Endpoint: %s\n\n", endpoint_param))
  cat(sprintf("Overall (N=%d)\n", n_total))
  
  cat("Number of Events\n")
  cat(sprintf("%d (%.1f%%)\n", n_events, (n_events / n_total) * 100))
  
  cat("Number of Censored Subjects\n")
  cat(sprintf("%d (%.1f%%)\n", n_censored, (n_censored / n_total) * 100))
  
  for (i in seq_len(nrow(censor_reasons))) {
    cat(sprintf("%s\n", censor_reasons$EVNTDESC[i]))
    cat(sprintf("%d (%.1f%%)\n", censor_reasons$Count[i], censor_reasons$Percent[i]))
  }
  
  # Step F: Export Dataset (SITEID is missing, so using STUDYID instead)
  export_df <- df_filtered %>%
    filter(CNSR > 0) %>%
    select(STUDYID, USUBJID, Censor_Reason = EVNTDESC)
  
  return(invisible(export_df))
}

# --- Test it on the pharmaverse dataset ---

# We will run it for Overall Survival (OS). 
# We leave pop_col = NULL since ITTFL isn't in these colnames.
cat("\n--- Running Feature --- \n\n")
export_data <- generate_censoring_summary(
  dataset = adtte_onco, 
  endpoint_param = "OS", 
  pop_col = NULL 
)

cat("\n--- Preview Export Data --- \n")
print(head(export_data, 3))
